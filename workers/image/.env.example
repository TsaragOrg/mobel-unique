APP_ENV=local
NODE_ENV=development
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
IMAGE_WORKER_HEARTBEAT_MS=60000

FABRIC_RENDER_QUEUE_NAME=local_fabric_render_jobs
FABRIC_RENDER_CLAIM_TTL_SECONDS=300
IN_HOME_SIMULATION_QUEUE_NAME=local_in_home_simulation_jobs
# SPEC-0015 PLAN-0057 reduced from 600s to 180s. The Edge Functions
# wall-clock is 150s; a 180s claim TTL gives the recovery cron a
# tight margin to detect a dead isolate within ~3 minutes.
IN_HOME_SIMULATION_CLAIM_TTL_SECONDS=180
# SPEC-0015 PLAN-0057 timeout (ms) on every internal Supabase
# REST/RPC/Storage call from the in-home simulation worker.
IN_HOME_SIMULATION_INTERNAL_FETCH_TIMEOUT_MS=30000
SIMULATION_RETENTION_HOURS=24

# Optional. Required only for explicit real-provider tests.
GEMINI_API_KEY=
OPENAI_API_KEY=
# SPEC-0015 PLAN-0056 abort-timeout (milliseconds) for OpenAI calls
# made by the in-home simulation worker. Defaults to 130000 when unset.
OPENAI_FETCH_TIMEOUT_MS=130000
