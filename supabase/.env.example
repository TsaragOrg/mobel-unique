APP_ENV=local
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

SPEC_0011_ADMIN_SMOKE_EMAIL=admin.local@mobel-unique.test
SPEC_0011_ADMIN_SMOKE_PASSWORD=mobel-unique-local-admin-password

WORKER_SMOKE_QUEUE_NAME=local_worker_smoke_jobs
FABRIC_RENDER_QUEUE_NAME=local_fabric_render_jobs
FABRIC_RENDER_MAX_ATTEMPTS=3
# Leave empty for the worker default. Local Gemini runs sequentially by default
# to avoid Supabase Edge runtime CPU cancellation; deployed/mock defaults to 3.
FABRIC_RENDER_MAX_CONCURRENT_JOBS=
FABRIC_RENDER_CLAIM_TTL_SECONDS=300
# Worker-owned provider selection. Use gemini in deployed environments.
FABRIC_RENDER_PROVIDER=mock
FABRIC_RENDER_PROVIDER_MODEL=mock-fabric-render-v1
# Local default preserves Gemini provider output to avoid Supabase CLI Edge
# runtime CPU cancellation. Use strict to test exact crop/resize normalization.
FABRIC_RENDER_OUTPUT_NORMALIZATION=
# Leave empty for local Edge Function self-invocation. Host-side scripts and
# the Next admin API can still use http://127.0.0.1:54321/functions/v1/fabric-render-worker.
FABRIC_RENDER_WORKER_FUNCTION_URL=
FABRIC_RENDER_WORKER_INVOKE_SECRET=
FABRIC_RENDER_ENABLE_GEMINI_SMOKE=0
FABRIC_RENDER_WORKER_SMOKE_REQUEST_ID=

# In-home simulation worker (SPEC-0007).
# `IN_HOME_SIMULATION_PROVIDER_MODE=mock` is the safe default that uses
# in-process placeholders instead of any AI provider. Switch to `live`
# once OPENAI_API_KEY (and optionally GEMINI_API_KEY) is set below.
IN_HOME_SIMULATION_QUEUE_NAME=local_in_home_simulation_jobs
IN_HOME_SIMULATION_CLAIM_TTL_SECONDS=600
IN_HOME_SIMULATION_WORKER_ID_PREFIX=edge
# Maximum jobs processed in parallel per Edge Function invocation. Each
# job claims its own row atomically; concurrency is bounded by the
# helper in lib/concurrency.ts.
IN_HOME_SIMULATION_MAX_CONCURRENT_JOBS=1
# Optional override for the per-stage attempt cap (defaults to the
# job-row column `max_attempts_per_stage`).
IN_HOME_SIMULATION_MAX_ATTEMPTS=3
IN_HOME_SIMULATION_MAX_EDGE_PX=720
IN_HOME_SIMULATION_TMP_DIR=
IN_HOME_SIMULATION_PROVIDER_MODE=mock
# In `mock` mode, set to `corner` to exercise the corner geometry path
# end-to-end without a live model. Default is `back_wall`.
IN_HOME_SIMULATION_MOCK_GEOMETRY_MODE=back_wall
IN_HOME_SIMULATION_MAX_GEOMETRY_ATTEMPTS=3
# Set to `gemini` to wrap the OpenAI placement provider in a fallback
# that retries through Gemini when the primary fails. Requires both
# OPENAI_API_KEY and GEMINI_API_KEY.
IN_HOME_SIMULATION_FALLBACK_PROVIDER=
IN_HOME_SIMULATION_PURGE_BATCH_SIZE=50
IN_HOME_SIMULATION_ORPHAN_MIN_AGE_HOURS=1
# Capped at the SPEC-0003 maximum of 24 hours.
SIMULATION_RETENTION_HOURS=24

# Required for IN_HOME_SIMULATION_PROVIDER_MODE=live and for the Gemini
# fallback. Both keys must be server-side only and must never reach the
# browser per SPEC-0007 Users And Permissions.
GEMINI_API_KEY=
OPENAI_API_KEY=
