APP_ENV=local
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
FABRIC_RENDER_WORKER_FUNCTION_URL=http://127.0.0.1:54321/functions/v1/fabric-render-worker
FABRIC_RENDER_WORKER_INVOKE_SECRET=

# SPEC-0015 PLAN-0040/PLAN-0074 public simulation API.
# SUPABASE_SERVICE_ROLE_KEY is consumed server-side only by the public
# simulation route handlers for storage upload + RPC invocation; it
# must never reach the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Supabase project JWT secret used server-side to mint short-lived,
# per-simulation Realtime tokens. Never expose this with NEXT_PUBLIC_.
SUPABASE_JWT_SECRET=
# HMAC secret used to sign and validate the opaque application
# `simulation_access_token`. Supabase Auth verifies the email OTP, but
# public simulation actions continue to use this application-owned token.
SIMULATION_ACCESS_TOKEN_SECRET=
# Per-environment secret used to hash IPs and short-lived verified-email
# subjects before they are written to `simulation_rate_limits`. Rotating
# the secret invalidates existing rate-limit windows.
SIMULATION_RATE_LIMIT_SUBJECT_SALT=
# Daily rate limits enforced inside POST /api/public/simulations.
SIMULATION_RATE_LIMIT_IP_PER_DAY=3
SIMULATION_RATE_LIMIT_EMAIL_PER_DAY=2
# Optional local-only developer bypass for the public simulation OTP screen.
# Requires APP_ENV=local and NEXT_PUBLIC_APP_ENV=local. Never set this in DEV
# or PROD.
# SIMULATION_EMAIL_OTP_BYPASS_CODE=000000
# Server-only wake-up used by the public simulation API after it has
# committed the job/checkpoint state to Supabase. This is not a browser
# variable and must not be prefixed with NEXT_PUBLIC_.
IN_HOME_SIMULATION_WORKER_FUNCTION_URL=http://127.0.0.1:54321/functions/v1/in-home-simulation-worker
IN_HOME_SIMULATION_WORKER_INVOKE_SECRET=
IN_HOME_SIMULATION_DISPATCH_TRIGGER_TIMEOUT_MS=5000
# Slug of the public_tag that marks a sofa as corner-shape. PLAN-0042
# confirms the catalog-owner-approved value before launch; until
# then the placeholder value `corner` is used.
SIMULATION_CORNER_TAG_SLUG=corner
# Capped at the SPEC-0003 maximum of 24 hours. Mirrors the worker
# config in supabase/.env.example.
SIMULATION_RETENTION_HOURS=24
# Public origin used by Supabase Auth email templates and frontend links.
# Local development should use http://localhost:3000.
NEXT_PUBLIC_SITE_URL=
