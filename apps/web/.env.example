APP_ENV=local
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
FABRIC_RENDER_WORKER_FUNCTION_URL=http://127.0.0.1:54321/functions/v1/fabric-render-worker
FABRIC_RENDER_WORKER_INVOKE_SECRET=

# SPEC-0015 PLAN-0040 public simulation API.
# SUPABASE_SERVICE_ROLE_KEY is consumed server-side only by the public
# simulation route handlers for storage upload + RPC invocation; it
# must never reach the browser.
SUPABASE_SERVICE_ROLE_KEY=
# HMAC secret used to sign and validate the launch-window stub
# `simulation_access_token`. The catalog owner replaces the stub with
# real email verification later; this secret stays in place to scope
# tokens to the deployment environment.
SIMULATION_ACCESS_TOKEN_SECRET=
# Per-environment salt used to hash IPs and emails before they are
# written to `simulation_rate_limits`. Rotating the salt invalidates
# existing rate-limit windows.
SIMULATION_RATE_LIMIT_SUBJECT_SALT=
# Daily rate limits enforced inside POST /api/public/simulations.
SIMULATION_RATE_LIMIT_IP_PER_DAY=3
SIMULATION_RATE_LIMIT_EMAIL_PER_DAY=2
# pgmq queue name shared with the in-home simulation worker. Must
# match `IN_HOME_SIMULATION_QUEUE_NAME` in `supabase/.env.example`.
SIMULATION_QUEUE_NAME=local_in_home_simulation_jobs
# Slug of the public_tag that marks a sofa as corner-shape. PLAN-0042
# confirms the catalog-owner-approved value before launch; until
# then the placeholder value `corner` is used.
SIMULATION_CORNER_TAG_SLUG=corner
# Capped at the SPEC-0003 maximum of 24 hours. Mirrors the worker
# config in supabase/.env.example.
SIMULATION_RETENTION_HOURS=24
# Public origin used by future email-verification links. Optional
# during the launch-window stub; required when the catalog owner
# ships real verification.
NEXT_PUBLIC_SITE_URL=
