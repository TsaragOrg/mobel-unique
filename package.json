{
  "name": "mobel-unique",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @mobel-unique/web --filter @mobel-unique/api --filter @mobel-unique/image-worker dev",
    "dev:web": "pnpm --filter @mobel-unique/web dev",
    "dev:api": "pnpm --filter @mobel-unique/api dev",
    "dev:worker": "pnpm --filter @mobel-unique/image-worker dev",
    "branch:create": "node scripts/create-branch.mjs",
    "spec:check": "node scripts/spec-guard.mjs",
    "test": "vitest run scripts/create-branch.test.mjs scripts/spec-guard.test.mjs && pnpm -r test",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm spec:check && pnpm typecheck && pnpm test && pnpm build",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "vitest": "^2.1.0"
  }
}
